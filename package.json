{
    "name":  "loja-construcao",
    "version": "1.1.3",
    "description":  "Sistema de gestão para loja de materiais de construção - Msdos Informatica",
    "main":  "out/main/index.js",
    "author":  "Msdos Informatica",
    "scripts":  {
                    "dev":  "electron-vite dev",
                    "build":  "electron-vite build",
                    "dist":  "electron-vite build \u0026\u0026 electron-builder --win --publish never",
                    "dist:publish":  "electron-vite build \u0026\u0026 electron-builder --win --publish always",
                    "postinstall":  "electron-rebuild -f -w better-sqlite3",
                    "obfuscate":  "javascript-obfuscator out/main/index.js --output out/main/index.js --compact true --string-array true --string-array-encoding base64 --string-array-threshold 0.75 --identifier-names-generator hexadecimal --target node",
                    "build:secure":  "npm run build \u0026\u0026 npm run obfuscate"
                },
    "dependencies":  {
                         "better-sqlite3":  "^9.4.3",
                         "electron-log":  "^5.4.4",
                         "electron-updater":  "^6.8.9",
                         "jspdf":  "^2.5.1",
                         "jspdf-autotable":  "^3.8.2",
                         "lucide-react":  "^0.344.0",
                         "react":  "^18.2.0",
                         "react-dom":  "^18.2.0",
                         "react-router-dom":  "^6.22.0",
                         "xlsx":  "^0.18.5"
                     },
    "devDependencies":  {
                            "@electron-toolkit/preload":  "^3.0.1",
                            "@electron-toolkit/utils":  "^3.0.0",
                            "@electron/rebuild":  "^3.6.0",
                            "@types/better-sqlite3":  "^7.6.8",
                            "@types/node":  "^20.11.5",
                            "@types/react":  "^18.2.48",
                            "@types/react-dom":  "^18.2.18",
                            "@vitejs/plugin-react":  "^4.2.1",
                            "autoprefixer":  "^10.4.17",
                            "electron":  "^29.4.6",
                            "electron-builder":  "^24.9.1",
                            "electron-vite":  "^2.0.0",
                            "javascript-obfuscator":  "^5.4.7",
                            "postcss":  "^8.4.33",
                            "tailwindcss":  "^3.4.1",
                            "terser":  "^5.49.0",
                            "typescript":  "^5.3.3",
                            "vite":  "^5.0.12"
                        }
}
